<style>
/* Splash overlay */
#splash {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0e1a;
    cursor: pointer;
}
.splash-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 0%, #0d2b4e 0%, #0a0e1a 65%);
    z-index: 0;
}
.splash-stars { position: absolute; inset: 0; z-index: 1; }
.splash-star {
    position: absolute; background: white; border-radius: 50%;
    animation: splTwinkle var(--dur, 2s) ease-in-out infinite var(--delay, 0s);
}
@keyframes splTwinkle {
    0%,100%{ opacity:.2; transform:scale(1);   }
    50%    { opacity:1;  transform:scale(1.4); }
}
/* Road */
.splash-road {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 38%; z-index: 2; overflow: hidden;
}
.splash-road-surface {
    position: absolute; inset: 0;
    background: linear-gradient(to top, #111318 0%, #1a1d2e 100%);
}
.splash-road-surface::before {
    content: '';
    position: absolute; bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 0; height: 0;
    border-left: 30vw solid transparent;
    border-right: 30vw solid transparent;
    border-bottom: 38vh solid #1e2235;
}
.splash-dashes {
    position: absolute; bottom: 0; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column;
    align-items: center; width: 6px; height: 100%; overflow: hidden;
}
.splash-dash {
    width: 4px; height: 28px; background: rgba(79,172,254,.55);
    border-radius: 2px; flex-shrink: 0; margin-bottom: 18px;
    animation: splDash .6s linear infinite;
}
@keyframes splDash {
    0%  { transform: translateY(-46px); }
    100%{ transform: translateY(0); }
}
.splash-horizon {
    position: absolute; bottom: 38%; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, rgba(79,172,254,.6) 30%, #4facfe 50%, rgba(79,172,254,.6) 70%, transparent 100%);
    z-index: 3;
    animation: splHorizon 3s ease-in-out infinite;
}
@keyframes splHorizon {
    0%,100%{ opacity:.6; filter:blur(1px); }
    50%    { opacity:1;  filter:blur(0); }
}
/* Rings */
.splash-rings {
    position: absolute; bottom: calc(38% - 6px); left: 50%;
    transform: translateX(-50%); z-index: 5;
}
.splash-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(79,172,254,.4);
    top:50%; left:50%;
    transform: translate(-50%,-50%) scale(0);
    animation: splRing 2s ease-out infinite;
}
.splash-ring:nth-child(1){ animation-delay:1.8s; }
.splash-ring:nth-child(2){ animation-delay:2.3s; }
.splash-ring:nth-child(3){ animation-delay:2.8s; }
@keyframes splRing {
    0%  { width:20px;  height:10px; opacity:.8; transform:translate(-50%,-50%) scale(1); }
    100%{ width:300px; height:60px; opacity:0;  transform:translate(-50%,-50%) scale(1); }
}
/* Beams */
.splash-beams {
    position: absolute; bottom: calc(38% - 4px); left: 50%;
    transform: translateX(-50%); z-index: 9;
    animation: splCarArrive 1.2s cubic-bezier(.16,1,.3,1) .3s both;
}
.splash-beam {
    position: absolute; bottom: 12px;
    width: 0; height: 0; border-style: solid; opacity: .35;
}
.splash-beam-l {
    right: calc(50% + 28px);
    border-width: 6px 0 6px 90px;
    border-color: transparent transparent transparent rgba(255,240,180,.5);
    transform: rotate(-4deg); filter: blur(3px);
}
.splash-beam-r {
    left: calc(50% + 28px);
    border-width: 6px 90px 6px 0;
    border-color: transparent rgba(255,240,180,.5) transparent transparent;
    transform: rotate(4deg); filter: blur(3px);
}
/* Car */
.splash-car-wrap {
    position: absolute; bottom: calc(38% - 4px); left: 50%;
    transform: translateX(-50%); z-index: 10;
    animation: splCarArrive 1.2s cubic-bezier(.16,1,.3,1) .3s both;
}
@keyframes splCarArrive {
    0%  { transform:translateX(-50%) translateY(80px) scale(.4); opacity:0; }
    60% { transform:translateX(-50%) translateY(-8px) scale(1.02); opacity:1; }
    80% { transform:translateX(-50%) translateY(3px) scale(.99); }
    100%{ transform:translateX(-50%) translateY(0) scale(1); }
}
.splash-car {
    width: 110px;
    filter: drop-shadow(0 0 18px rgba(79,172,254,.8)) drop-shadow(0 4px 8px rgba(0,0,0,.6));
    animation: splCarFloat 3s ease-in-out 1.5s infinite;
}
@keyframes splCarFloat {
    0%,100%{ transform:translateY(0); }
    50%    { transform:translateY(-5px); }
}
/* Speed lines */
.splash-speed {
    position: absolute; bottom: calc(38% + 10px); left: 0; right: 0;
    height: 60px; z-index: 6; overflow: hidden;
    opacity: 0; animation: splSpeedIn .4s ease .8s forwards;
}
@keyframes splSpeedIn{ to{ opacity:1; } }
.splash-speed-line {
    position: absolute; height: 1.5px;
    background: linear-gradient(90deg, transparent, rgba(79,172,254,.5), transparent);
    border-radius: 2px;
    animation: splSpeedMove var(--spd,.5s) linear infinite var(--del,0s);
}
@keyframes splSpeedMove {
    0%  { transform:translateX(-60%); opacity:0; }
    30% { opacity:1; }
    70% { opacity:1; }
    100%{ transform:translateX(60%); opacity:0; }
}
/* Brand */
.splash-brand {
    position: relative; z-index: 20;
    text-align: center; margin-bottom: 8%;
    animation: splBrand .8s cubic-bezier(.16,1,.3,1) 1.4s both;
}
@keyframes splBrand {
    0%  { opacity:0; transform:translateY(-24px) scale(.9); }
    100%{ opacity:1; transform:translateY(0) scale(1); }
}
.splash-logo-img {
    width: 130px;
    filter: drop-shadow(0 0 24px rgba(79,172,254,.9)) drop-shadow(0 0 8px rgba(0,242,254,.6));
    animation: splLogoPulse 2.5s ease-in-out 2.2s infinite;
}
@keyframes splLogoPulse {
    0%,100%{ filter:drop-shadow(0 0 24px rgba(79,172,254,.9)) drop-shadow(0 0 8px rgba(0,242,254,.6)); }
    50%    { filter:drop-shadow(0 0 36px rgba(79,172,254,1))   drop-shadow(0 0 16px rgba(0,242,254,.9)); }
}
.splash-brand-name {
    font-family: 'Righteous', cursive;
    font-size: 52px; letter-spacing: 4px; line-height: 1;
    margin-top: 6px; position: relative; overflow: hidden;
    background: linear-gradient(135deg, #ffffff 0%, #4facfe 50%, #00f2fe 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.splash-brand-name span {
    display: inline-block;
    animation: splLetter .5s cubic-bezier(.34,1.56,.64,1) both;
}
.splash-brand-name span:nth-child(1){ animation-delay:1.5s; }
.splash-brand-name span:nth-child(2){ animation-delay:1.62s; }
.splash-brand-name span:nth-child(3){ animation-delay:1.74s; }
.splash-brand-name span:nth-child(4){ animation-delay:1.86s; }
.splash-brand-name span:nth-child(5){ animation-delay:1.98s; }
.splash-brand-name span:nth-child(6){ animation-delay:2.1s; }
@keyframes splLetter {
    0%  { opacity:0; transform:translateY(30px) rotate(-8deg) scale(.5); }
    70% { transform:translateY(-4px) rotate(2deg) scale(1.1); }
    100%{ opacity:1; transform:translateY(0) rotate(0) scale(1); }
}
.splash-shimmer {
    position: absolute; top:0; left:-100%; width:60%; height:100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.4), transparent);
    transform: skewX(-20deg);
    animation: splShimmer .7s ease 2.6s forwards;
}
@keyframes splShimmer { 0%{ left:-100%; } 100%{ left:160%; } }
.splash-tagline {
    font-size: 13px; font-weight: 300; letter-spacing: 3px;
    text-transform: uppercase; color: rgba(255,255,255,.5); margin-top: 8px;
    animation: splTagline .6s ease 2.4s both;
}
@keyframes splTagline {
    0%  { opacity:0; letter-spacing:8px; }
    100%{ opacity:1; letter-spacing:3px; }
}
/* Dots */
.splash-dots {
    position: absolute; bottom: 12%; left: 50%; transform: translateX(-50%);
    display: flex; gap: 8px; z-index: 20;
    animation: splDotsIn .4s ease 2.2s both;
}
@keyframes splDotsIn{ from{opacity:0;} to{opacity:1;} }
.splash-dot {
    width:7px; height:7px; border-radius:50%; background:#4facfe;
    animation: splDotBounce 1.2s ease-in-out infinite;
}
.splash-dot:nth-child(1){ animation-delay:0s; }
.splash-dot:nth-child(2){ animation-delay:.15s; background:#00f2fe; }
.splash-dot:nth-child(3){ animation-delay:.3s; }
@keyframes splDotBounce {
    0%,80%,100%{ transform:scale(.7); opacity:.4; }
    40%        { transform:scale(1.2); opacity:1; }
}
/* Exit */
#splash.spl-exit {
    animation: splExit .6s cubic-bezier(.55,0,1,.45) forwards;
}
@keyframes splExit {
    0%  { opacity:1; transform:scale(1); }
    100%{ opacity:0; transform:scale(1.08); pointer-events:none; }
}
</style>

