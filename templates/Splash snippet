<script>
(function(){
    /* Stars */
    var starsEl = document.getElementById('splStars');
    for(var i=0;i<80;i++){
        var s=document.createElement('div'); s.className='splash-star';
        var sz=Math.random()*2.5+0.5;
        s.style.cssText='width:'+sz+'px;height:'+sz+'px;top:'+(Math.random()*62)+'%;left:'+(Math.random()*100)+'%;--dur:'+(Math.random()*3+1.5).toFixed(1)+'s;--delay:'+(Math.random()*3).toFixed(1)+'s;';
        starsEl.appendChild(s);
    }
    /* Dashes */
    var dEl=document.getElementById('splDashes');
    for(var i=0;i<10;i++){var d=document.createElement('div');d.className='splash-dash';dEl.appendChild(d);}
    /* Speed lines */
    var spEl=document.getElementById('splSpeed');
    for(var i=0;i<14;i++){
        var l=document.createElement('div'); l.className='splash-speed-line';
        var w=Math.random()*80+40;
        l.style.cssText='width:'+w+'px;top:'+(Math.random()*100)+'%;left:'+(Math.random()*60+20)+'%;--spd:'+(Math.random()*0.4+0.3).toFixed(2)+'s;--del:'+(Math.random()*0.5).toFixed(2)+'s;';
        spEl.appendChild(l);
    }
    /* Show only once per session */
    function dismiss(){
        var el=document.getElementById('splash');
        if(!el||el.classList.contains('spl-exit')) return;
        el.classList.add('spl-exit');
        setTimeout(function(){el.style.display='none';},650);
    }
    /* Show splash only on first visit per session */
    if(sessionStorage.getItem('splashShown')){
        document.getElementById('splash').style.display='none';
    } else {
        sessionStorage.setItem('splashShown','1');
        setTimeout(dismiss, 3600);
        document.getElementById('splash').addEventListener('click', dismiss);
    }
})();
</script>
